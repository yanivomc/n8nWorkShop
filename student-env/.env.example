# ── Set automatically by setup.sh ────────────────────────────────────
MASTER_IP=
CLUSTER_HOST=

# ── n8n ──────────────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=changeme123
EC2_PUBLIC_IP=

# ── MCP Server ────────────────────────────────────────────────────────
# Auto-populated by setup.sh option 6 (Install Prometheus + Grafana)
# Do NOT set this manually — it uses the AWS LoadBalancer hostname
PROMETHEUS_URL=
KUBECONFIG_PATH=/home/ubuntu/.kube/config
# Generate: openssl rand -hex 32
WRITE_APPROVAL_TOKEN=

# ── Gemini ────────────────────────────────────────────────────────────
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── ngrok (required for S4 Telegram Trigger)
# Get free static domain: https://dashboard.ngrok.com/domains
NGROK_AUTH_TOKEN=
NGROK_DOMAIN=

# ── Telegram ─────────────────────────────────────────────────────────
# Create via @BotFather
TELEGRAM_BOT_TOKEN=
# Get your chat ID from @userinfobot
TELEGRAM_CHAT_ID=
