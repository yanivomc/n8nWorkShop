# ── n8n ──────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=changeme123

# ── MCP Server ────────────────────────────────────────
# Prometheus URL inside the cluster (via port-forward or NodePort)
PROMETHEUS_URL=http://<CLUSTER_NODE_IP>:30090

# Token n8n sends to MCP write endpoint after Telegram approval
# Generate: openssl rand -hex 32
WRITE_APPROVAL_TOKEN=

# Path to your cluster kubeconfig on this EC2
KUBECONFIG_PATH=/home/ubuntu/.kube/config

# EC2 public IP (for n8n webhook URLs)
EC2_PUBLIC_IP=

# ── Gemini ────────────────────────────────────────────
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Telegram ─────────────────────────────────────────
# Create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Your personal Telegram chat ID (get from @userinfobot)
TELEGRAM_CHAT_ID=
