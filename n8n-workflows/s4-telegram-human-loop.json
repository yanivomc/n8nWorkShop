    {
      "parameters": {
        "jsCode": "const text = $input.first().json.text.trim();\nconst chatId = $input.first().json.chatId;\nconst from = $input.first().json.from;\n\nif (text.startsWith('/deny')) {\n  const store = $getWorkflowStaticData('global');\n  if (store.pending) delete store.pending[chatId];\n  return [{ json: { route: 'deny', chatId, message: '\u274c Action denied by ' + from + '. No changes made.' } }];\n}\n\nconst parts = text.split(' ');\n// /approve <totp> <key>\nif (parts.length < 3) {\n  return [{ json: { route: 'deny', chatId, message: '\u26a0\ufe0f Format: /approve <6-digit-totp> <incident-key>\\nExample: /approve 123456 k42a' } }];\n}\n\nconst totpCode = parts[1];\nconst incidentKey = parts[2];\n\nreturn [{ json: { route: 'approval', chatId, incidentKey, approvedBy: from, token: totpCode, useKey: true } }];"
      },
      "id": "f0904892-8540-44fe-a7cd-046b733e6578",
      "name": "Validate Approval",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        7808,
        816
