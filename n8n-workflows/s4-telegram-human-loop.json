    {
      "parameters": {
        "jsCode": "const text = $input.first().json.text;\nconst chatId = $input.first().json.chatId;\nconst from = $input.first().json.from;\nconst expectedToken = $vars.WRITE_APPROVAL_TOKEN || '';\n\n// Route field so IF node can split\nif (text.startsWith('/deny')) {\n  return [{ json: { route: 'deny', chatId, message: '\u274c Action denied by ' + from + '. No changes made.' } }];\n}\n\nconst parts = text.split(' ');\nconst token = parts[1] || '';\nconst command = parts.slice(2).join(' ');\n\nif (!expectedToken || token !== expectedToken) {\n  return [{ json: { route: 'deny', chatId, message: '\ud83d\udd12 Invalid approval token. Action blocked.' } }];\n}\n\nreturn [{ json: { route: 'approve', chatId, command, approvedBy: from, token } }];"
      },
