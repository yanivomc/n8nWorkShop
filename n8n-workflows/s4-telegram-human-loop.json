    {
      "parameters": {
        "jsCode": "const text = $input.first().json.text.trim();\nconst chatId = $input.first().json.chatId;\nconst from = $input.first().json.from;\n\nif (text.startsWith('/deny')) {\n  const store = $getWorkflowStaticData('global');\n  if (store.pending) delete store.pending[chatId];\n  console.log(JSON.stringify({ event: 'DENIED', user: from, chatId, timestamp: new Date().toISOString() }));\n  return [{ json: { route: 'deny', chatId, message: '\u274c Action denied by ' + from + '. No changes made.' } }];\n}\n\n// Parse: /approve <totp> [optional-key]\nconst parts = text.split(' ');\nconst totpCode = parts[1] || '';\nconst incidentKey = parts[2] || null;\n\nif (incidentKey) {\n  // S5 incident flow \u2014 key provided, look up from MCP\n  console.log(JSON.stringify({ event: 'APPROVE_BY_KEY', user: from, chatId, incidentKey, timestamp: new Date().toISOString() }));\n  return [{ json: { route: 'approval', chatId, incidentKey, approvedBy: from, token: totpCode, useKey: true } }];\n} else {\n  // Normal chat flow \u2014 look up from static data\n  const store = $getWorkflowStaticData('global');\n  const pending = store.pending?.[chatId];\n  if (!pending) {\n    return [{ json: { route: 'deny', chatId, message: '\u26a0\ufe0f No pending action. Ask your question first or provide an incident key.' } }];\n  }\n  const command = pending.command;\n  delete store.pending[chatId];\n  console.log(JSON.stringify({ event: 'APPROVE_BY_STATIC', user: from, chatId, command, timestamp: new Date().toISOString() }));\n  return [{ json: { route: 'approval', chatId, command, approvedBy: from, token: totpCode, useKey: false } }];\n}"
      },
