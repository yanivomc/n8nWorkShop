    {
      "parameters": {
        "jsCode": "const output = $input.first().json.output || '';\nconst chatId = $('Route Message').first().json.chatId;\nconst match = output.match(/SRE_ACTION:\\s*(.+)/);\nif (match) {\n  // Strip leading 'kubectl ' if Gemini included it\n  const cmd = match[1].trim().replace(/^kubectl\\s+/i, '');\n  const store = $getWorkflowStaticData('global');\n  if (!store.pending) store.pending = {};\n  store.pending[chatId] = { command: cmd };\n  return [{ json: {\n    needsApproval: true,\n    chatId,\n    approvalPrompt: '\u26a0\ufe0f <b>SRE Action suggested:</b>\\n<code>kubectl ' + cmd + '</code>\\n\\n\ud83d\udd10 Enter your 6-digit Authenticator code:\\n\u2705 <code>/approve &lt;6-digit-code&gt;</code>\\n\u274c <code>/deny</code>'\n  }}];\n}\nreturn [{ json: { needsApproval: false, chatId, message: output } }];"
      },
