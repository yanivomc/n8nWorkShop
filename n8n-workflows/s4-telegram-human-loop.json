    {
      "parameters": {
        "jsCode": "const msg = $input.first().json.message;\nconst text = (msg?.text || '').trim();\nconst chatId = msg?.chat?.id?.toString();\nconst from = msg?.from?.first_name || 'Engineer';\nconst route = (text.startsWith('/approve ') || text.startsWith('/deny ')) ? 'approval' : 'query';\nreturn [{ json: { route, text, chatId, from } }];"
      },
      "id": "459ca681-c9a1-4e19-986a-b5fc33c0666b",
      "name": "Route Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1952,
        384
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.from }} asks: {{ $json.text }}\n\nAnswer using kubectl_read and/or promql. Be concise \u2014 this is a Telegram chat reply.\nFormat your response clearly with emojis. Keep it under 300 words.",
        "options": {
          "systemMessage": "You are a Kubernetes SRE assistant helping engineers via Telegram chat.\n\nYou have two tools:\n1. kubectl_read \u2014 read-only kubectl. Parameter: \"command\"\n2. promql \u2014 PromQL queries. Parameter: \"query\" (single quotes for label selectors)\n\nAlways run at least one tool. Be concise, use emojis (\u2705 \u274c \u26a0\ufe0f \ud83d\udcca).\n\nAfter investigating, if the situation would benefit from a cluster operation, end your response with this line:\nSRE_ACTION: <kubectl subcommand and flags>\nExample: SRE_ACTION: rollout restart deployment/payments-app -n prod\n\nThis is a structured suggestion field only. You are not running anything."
        }
      },
      "id": "892c14c5-9024-431c-bfe2-f031d19ff1a4",
      "name": "K8s Assistant",
      "type": "@n8n/n8n-nodes-langchain.agent",
